{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StemDeck",
  "version": "0.1.0-alpha.0",
  "identifier": "app.stemdeck.desktop",
  "build": {
    "frontendDist": "../ui",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "StemDeck",
        "width": 1440,
        "height": 900,
        "minWidth": 1440,
        "minHeight": 900,
        "backgroundColor": "#050b10",
      "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}
